# Nanocode v0.4 - Environment Configuration

# Brain Selection (uncomment the one you want to use)
NANOCODE_BRAIN=zai
# NANOCODE_BRAIN=claude
# NANOCODE_BRAIN=deepseek

# Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Z.ai Coding Plan Configuration
ZAI_CODING_API_KEY=your_zai_coding_api_key_here

# Z.ai Model Selection
ZAI_CODING_MODEL=GLM-4.7

# Z.ai API Endpoint Configuration (Optional)
# Default: https://api.z.ai/api/anthropic/v1/messages
# ZAI_CODING_BASE_URL=https://api.z.ai
# ZAI_CODING_PATH=/api/anthropic/v1/messages
